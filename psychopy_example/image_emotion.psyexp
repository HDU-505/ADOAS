      <CodeComponent name="code" plugin="None">
        <Param val="import socket&amp;#10;from datetime import datetime&amp;#10;#开始时的时间戳&amp;#10;timebegin = int(datetime.now().timestamp()*1000)&amp;#10;# 定义主机和端口&amp;#10;host = 'localhost'&amp;#10;port = 7777&amp;#10;# 创建一个套接字对象&amp;#10;#server_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)&amp;#10;# 绑定套接字到指定的主机和端口&amp;#10;#server_socket.connect((host, port))&amp;#10;#编号规则&amp;#10;MEclass=11&amp;#10;OTHERSclass=12&amp;#10;ANXIETYclass=13&amp;#10;CALMNESSclass=14&amp;#10;correctTask1=15&amp;#10;wrongTask1=16&amp;#10;&amp;#10;SUICIDEclass=21&amp;#10;POSITIVEclass=22&amp;#10;NEGATIVEclass=23&amp;#10;NEUTRALclass=24&amp;#10;correctTask2=25&amp;#10;wrongTask2=26&amp;#10;&amp;#10;stopwatchappears=31&amp;#10;tooearly=32&amp;#10;correctTask3=33&amp;#10;overrun=34&amp;#10;&amp;#10;startOfTheParadigm=&quot;start_paradigm&quot;&amp;#10;endOfTheParadigm=&quot;end_paradigm&quot;&amp;#10;startClosingEyes=&quot;start_closeeye&quot;&amp;#10;endClosingEyes=&quot;end_closeeye&quot;&amp;#10;startOpeningEyes=&quot;start_openeye&quot;&amp;#10;endOpeningEyes=&quot;end_openeye&quot;&amp;#10;startTask=&quot;start_task&quot;&amp;#10;endTask=&quot;end_task&quot;&amp;#10;&amp;#10;oneTaskStart=&quot;start_onetask&quot;&amp;#10;oneTaskEnd=&quot;end_onetask&quot;&amp;#10;oneBlankStart=&quot;start_oneblank&quot;&amp;#10;oneBlankEnd=&quot;end_oneblank&quot;&amp;#10;&amp;#10;&amp;#10;" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="import * as socket from 'socket';&amp;#10;import {datetime} from 'datetime';&amp;#10;timebegin = Number.parseInt((datetime.now().timestamp() * 1000));&amp;#10;host = &quot;localhost&quot;;&amp;#10;port = 7777;&amp;#10;MEclass = 11;&amp;#10;OTHERSclass = 12;&amp;#10;ANXIETYclass = 13;&amp;#10;CALMNESSclass = 14;&amp;#10;correctTask1 = 15;&amp;#10;wrongTask1 = 16;&amp;#10;SUICIDEclass = 21;&amp;#10;POSITIVEclass = 22;&amp;#10;NEGATIVEclass = 23;&amp;#10;NEUTRALclass = 24;&amp;#10;correctTask2 = 25;&amp;#10;wrongTask2 = 26;&amp;#10;stopwatchappears = 31;&amp;#10;tooearly = 32;&amp;#10;correctTask3 = 33;&amp;#10;overrun = 34;&amp;#10;startOfTheParadigm = &quot;start_paradigm&quot;;&amp;#10;endOfTheParadigm = &quot;end_paradigm&quot;;&amp;#10;startClosingEyes = &quot;start_closeeye&quot;;&amp;#10;endClosingEyes = &quot;end_closeeye&quot;;&amp;#10;startOpeningEyes = &quot;start_openeye&quot;;&amp;#10;endOpeningEyes = &quot;end_openeye&quot;;&amp;#10;startTask = &quot;start_task&quot;;&amp;#10;endTask = &quot;end_task&quot;;&amp;#10;oneTaskStart = &quot;start_onetask&quot;;&amp;#10;oneTaskEnd = &quot;end_onetask&quot;;&amp;#10;oneBlankStart = &quot;start_oneblank&quot;;&amp;#10;oneBlankEnd = &quot;end_oneblank&quot;;&amp;#10;" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
